{
  "name": "knx-ip-ts",
  "version": "0.1.0",
  "description": "Pure-TypeScript KNX/IP client library — UDP tunnelling, KNX IP Secure over TCP, gateway discovery, DPT codecs, and ETS .knxproj parsing.",
  "author": "Jamel Nacef <jamelnacef@icloud.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamel-86/knx-ip-ts.git"
  },
  "homepage": "https://github.com/jamel-86/knx-ip-ts#readme",
  "bugs": {
    "url": "https://github.com/jamel-86/knx-ip-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node scripts/run-tests.mjs",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "knx",
    "knxip",
    "knxnet",
    "tunneling",
    "knx-secure",
    "ets",
    "home-automation",
    "typescript"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "fast-xml-parser": "^5.7.3"
  }
}
